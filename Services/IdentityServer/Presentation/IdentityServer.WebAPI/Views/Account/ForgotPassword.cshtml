@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    ViewData["Title"] = "Şifremi Unuttum";
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] | MultiShop</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <style>
        :root {
            --primary: #ffd333;
            --dark: #1a1c1e;
            --glass: rgba(255, 255, 255, 0.03);
            --glass-border: rgba(255, 255, 255, 0.08);
        }

        body {
            font-family: 'Outfit', sans-serif;
            background: radial-gradient(circle at bottom left, #2d2f31, #1a1c1e);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            margin: 0;
            padding: 20px;
        }

        .auth-card {
            background: var(--glass);
            backdrop-filter: blur(25px);
            border: 1px solid var(--glass-border);
            border-radius: 40px;
            width: 100%;
            max-width: 900px;
            display: flex;
            overflow: hidden;
            box-shadow: 0 40px 100px rgba(0,0,0,0.5);
            animation: cardAppear 0.8s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .side-info {
            background: var(--primary);
            width: 40%;
            padding: 50px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            color: var(--dark);
        }

        .form-area {
            width: 60%;
            padding: 60px;
            background: rgba(0,0,0,0.2);
        }

        .brand-text {
            font-size: 1.8rem;
            font-weight: 900;
            letter-spacing: -1px;
        }

        .input-box {
            position: relative;
            margin-bottom: 25px;
        }

        .input-box i {
            position: absolute;
            left: 20px;
            top: 50%;
            transform: translateY(-50%);
            color: rgba(255,255,255,0.3);
            transition: 0.3s;
        }

        .form-control {
            background: rgba(255,255,255,0.05) !important;
            border: 1px solid rgba(255,255,255,0.1) !important;
            border-radius: 18px !important;
            padding: 15px 20px 15px 55px !important;
            color: #fff !important;
            transition: all 0.3s;
        }

        .form-control:focus {
            background: rgba(255,255,255,0.08) !important;
            border-color: var(--primary) !important;
            box-shadow: 0 0 0 5px rgba(255, 211, 51, 0.1) !important;
        }

        .btn-submit {
            background: var(--primary);
            color: var(--dark);
            border: none;
            border-radius: 18px;
            padding: 16px;
            font-weight: 800;
            width: 100%;
            transition: all 0.3s;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(255, 211, 51, 0.2);
            filter: brightness(1.1);
        }

        .back-to-login {
            color: rgba(255,255,255,0.5);
            text-decoration: none;
            font-weight: 500;
            transition: 0.3s;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .back-to-login:hover {
            color: var(--primary);
        }

        @@keyframes cardAppear {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @@media (max-width: 768px) {
            .auth-card { flex-direction: column; }
            .side-info, .form-area { width: 100%; padding: 40px; }
            .side-info { order: 2; }
            .form-area { order: 1; }
        }
    </style>
</head>
<body>

    <div class="auth-card">
        <div class="side-info">
            <div class="mb-4 brand-text">
                <i class="fas fa-shield-alt me-2"></i>MultiShop
            </div>
            <h2 class="fw-bold mb-3">Güvenliğiniz Bizim İçin Önemli.</h2>
            <p class="opacity-75 mb-0">Şifrenizi unutmanız sorun değil. Kayıtlı e-posta adresinizi girerek şifre sıfırlama sürecini başlatabilirsiniz.</p>
        </div>

        <div class="form-area">
            <div class="mb-5">
                <a href="/Account/Login" class="back-to-login mb-4">
                    <i class="fas fa-arrow-left"></i> Giriş Yap'a Dön
                </a>
                <h3 class="fw-bold m-0 mt-2">Şifremi Unuttum</h3>
                <p class="text-white-50 small">Sıfırlama bağlantısı için e-posta adresinizi giriniz.</p>
            </div>

            <form asp-action="ForgotPassword" asp-controller="Account" method="post">
                <div class="input-box">
                    <i class="fas fa-envelope"></i>
                    <input name="email" type="email" class="form-control" placeholder="E-posta Adresiniz" required>
                </div>

                <button type="submit" class="btn-submit">
                    Sıfırlama Bağlantısı Gönder <i class="fas fa-paper-plane ms-2"></i>
                </button>
            </form>
        </div>
    </div>

</body>
</html>
