@{
    ViewData["Title"] = "E-posta Gönderildi";
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] | MultiShop</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <style>
        :root {
            --primary: #ffd333;
            --dark: #1a1c1e;
            --glass: rgba(255, 255, 255, 0.03);
            --glass-border: rgba(255, 255, 255, 0.08);
            --success: #2ecc71;
        }

        body {
            font-family: 'Outfit', sans-serif;
            background: radial-gradient(circle at bottom left, #2d2f31, #1a1c1e);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            margin: 0;
            padding: 20px;
        }

        .auth-card {
            background: var(--glass);
            backdrop-filter: blur(25px);
            border: 1px solid var(--glass-border);
            border-radius: 40px;
            width: 100%;
            max-width: 500px;
            padding: 60px 40px;
            text-align: center;
            box-shadow: 0 40px 100px rgba(0,0,0,0.5);
            animation: cardAppear 0.8s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .success-icon {
            width: 100px;
            height: 100px;
            background: rgba(46, 204, 113, 0.1);
            border: 2px solid var(--success);
            color: var(--success);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 40px;
            margin: 0 auto 30px;
            animation: pulse 2s infinite;
        }

        .btn-back {
            background: var(--primary);
            color: var(--dark);
            border: none;
            border-radius: 18px;
            padding: 16px 30px;
            font-weight: 800;
            margin-top: 30px;
            transition: all 0.3s;
            text-decoration: none;
            display: inline-block;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .btn-back:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(255, 211, 51, 0.2);
            color: var(--dark);
        }

        @@keyframes cardAppear {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @@keyframes pulse {
            0% { box-shadow: 0 0 0 0 rgba(46, 204, 113, 0.4); }
            70% { box-shadow: 0 0 0 20px rgba(46, 204, 113, 0); }
            100% { box-shadow: 0 0 0 0 rgba(46, 204, 113, 0); }
        }
    </style>
</head>
<body>

    <div class="auth-card">
        <div class="success-icon">
            <i class="fas fa-check"></i>
        </div>
        <h2 class="fw-bold mb-3">Talep Alındı!</h2>
        <p class="text-white-50">Eğer adresiniz sistemimizde kayıtlı ise, şifrenizi nasıl sıfırlayacağınızı içeren bir e-posta gönderdik.</p>
        <p class="small opacity-75 mt-3">Lütfen gereksiz (spam) klasörünüzü kontrol etmeyi unutmayın.</p>
        
        <a href="/Account/Login" class="btn btn-back">
            Giriş Sayfasına Dön
        </a>
    </div>

</body>
</html>
