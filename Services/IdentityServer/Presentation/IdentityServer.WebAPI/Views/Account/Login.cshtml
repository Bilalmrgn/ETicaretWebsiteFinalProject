@model IdentityServer.WebAPI.Models.LoginViewModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    ViewData["Title"] = "Giriş Yap";
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
        :root {
            --primary-dark: #1a1c1e;
            --accent-yellow: #ffd333;
            --soft-gray: #f4f7f9;
            --text-main: #3d464d;
            --text-muted: #718096;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: #f0f2f5;
            min-height: 100vh;
            display: flex;
            align-items: center;
        }

        .main-container {
            max-width: 1000px;
            width: 100%;
            margin: auto;
            padding: 20px;
        }

        .auth-card {
            background: #ffffff;
            border-radius: 32px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.08);
            overflow: hidden;
            border: 1px solid rgba(255,255,255,0.8);
            display: flex;
            min-height: 600px;
        }

        /* Sol Panel - Modern Gradient */
        .auth-side-panel {
            background: linear-gradient(135deg, #1a1c1e 0%, #3d464d 100%);
            padding: 60px;
            color: white;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            width: 40%;
        }

        .brand-logo {
            font-size: 1.5rem;
            font-weight: 800;
            letter-spacing: -0.5px;
            color: var(--accent-yellow);
        }

        .side-content h2 {
            font-weight: 700;
            line-height: 1.2;
            margin-bottom: 20px;
            font-size: 2.2rem;
        }

        .side-content p {
            color: rgba(255,255,255,0.7);
            font-size: 1.05rem;
            line-height: 1.6;
        }

        /* Sağ Panel - Form Alanı */
        .auth-form-panel {
            padding: 60px;
            width: 60%;
            background: #fff;
        }

        .form-header h3 {
            font-weight: 800;
            color: var(--primary-dark);
            font-size: 1.75rem;
            margin-bottom: 8px;
        }

        /* Inputlar - Minimalist ve Fokus Efektli */
        .form-label {
            font-size: 0.85rem;
            font-weight: 600;
            color: var(--text-muted);
            margin-bottom: 8px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .custom-input-group {
            position: relative;
            margin-bottom: 24px;
        }

            .custom-input-group i {
                position: absolute;
                left: 18px;
                top: 50%;
                transform: translateY(-50%);
                color: var(--text-muted);
                transition: color 0.3s ease;
            }

        .form-control-custom {
            width: 100%;
            padding: 14px 14px 14px 50px;
            background: var(--soft-gray);
            border: 2px solid transparent;
            border-radius: 16px;
            font-weight: 500;
            color: var(--primary-dark);
            transition: all 0.3s ease;
        }

            .form-control-custom:focus {
                background: #fff;
                border-color: var(--accent-yellow);
                box-shadow: 0 10px 20px rgba(255, 211, 51, 0.1);
                outline: none;
            }

                .form-control-custom:focus + i {
                    color: var(--primary-dark);
                }

        /* Modern Buton */
        .btn-submit {
            background: var(--primary-dark);
            color: #fff;
            border: none;
            padding: 16px;
            border-radius: 16px;
            font-weight: 700;
            width: 100%;
            margin-top: 10px;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

            .btn-submit:hover {
                background: #000;
                transform: translateY(-2px);
                box-shadow: 0 12px 24px rgba(0,0,0,0.15);
                color: var(--accent-yellow);
            }

        /* Checkbox & Links */
        .form-check-input:checked {
            background-color: var(--primary-dark);
            border-color: var(--primary-dark);
        }

        .forgot-link {
            color: var(--text-muted);
            text-decoration: none;
            font-size: 0.85rem;
            font-weight: 500;
        }

            .forgot-link:hover {
                color: var(--primary-dark);
            }

        .register-text {
            margin-top: 30px;
            text-align: center;
            font-size: 0.95rem;
            color: var(--text-muted);
        }

            .register-text a {
                color: var(--primary-dark);
                font-weight: 700;
                text-decoration: none;
            }

        /* Responsive */
        @@media (max-width: 992px) {
            .auth-side-panel {
                display: none;
            }

            .auth-form-panel {
                width: 100%;
                padding: 40px;
            }
        }
    </style>
</head>
<body>

    <div class="main-container">
        <div class="auth-card">
            <div class="auth-side-panel">
                <div class="brand-logo">
                    <i class="fas fa-shopping-bag me-2"></i>MULTISHOP
                </div>
                <div class="side-content">
                    <h2>Alışverişin Geleceğine Giriş Yap.</h2>
                    <p>En yeni trendler, sana özel indirimler ve güvenli ödeme seçenekleri sadece bir tık uzağında.</p>
                </div>
                <div class="side-footer">
                    <small class="opacity-50">© 2026 MultiShop Inc.</small>
                </div>
            </div>

            <div class="auth-form-panel">
                <div class="form-header">
                    <h3>Hoş Geldiniz</h3>
                    <p class="text-muted">Lütfen bilgilerinizi kullanarak oturum açın.</p>
                </div>

                <form asp-action="Login" asp-controller="Account" asp-route-returnUrl="@ViewBag.ReturnUrl" method="post" class="mt-5">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <div class="mb-3">
                        <label class="form-label">E-Posta Adresiniz</label>
                        <div class="custom-input-group">
                            <input type="email" asp-for="Email" class="form-control-custom" placeholder="isim@ornek.com" autocomplete="email">
                            <i class="fas fa-envelope"></i>
                        </div>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <div class="d-flex justify-content-between">
                            <label class="form-label">Şifreniz</label>
                            <a href="/Login/ForgotPassword" class="forgot-link">Şifremi Unuttum</a>
                        </div>
                        <div class="custom-input-group">
                            <input type="password" asp-for="Password" class="form-control-custom" placeholder="••••••••" autocomplete="current-password">
                            <i class="fas fa-lock"></i>
                        </div>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="d-flex align-items-center justify-content-between mb-4">
                        <div class="form-check">
                            <input type="checkbox" asp-for="RememberMe" class="form-check-input" id="rememberMe">
                            <label class="form-check-label small text-secondary" for="rememberMe">Beni Hatırla</label>
                        </div>
                    </div>

                    <button type="submit" class="btn-submit">
                        <span>Oturum Aç</span>
                        <i class="fas fa-arrow-right"></i>
                    </button>

                    <p class="register-text">
                        Hesabınız yok mu? <a href="/Register/Index">Şimdi Kayıt Olun</a>
                    </p>
                </form>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>

</body>
</html>