@model IdentityServer.WebAPI.Controllers.ErrorViewModel

<div class="error-page">
    <div class="lead">
        <h1>Error</h1>
        <p>Sorry, there was an error</p>
    </div>

    @if (Model.Error != null)
    {
        <strong>
            <em>
                : @Model.Error.Error
            </em>
        </strong>

        @if (Model.Error.ErrorDescription != null)
        {
            <div>@Model.Error.ErrorDescription</div>
        }
    }
</div>
