@model Frontend.DtosLayer.OrderDtos.ResultOrderDto

@{
    ViewData["Title"] = "Sipariş Özeti";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-header bg-primary bg-gradient text-white py-4 px-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h2 class="h4 mb-1">Sipariş Bilgileriniz</h2>
                            <p class="mb-0 opacity-75">Siparişiniz başarıyla oluşturuldu.</p>
                        </div>
                        <div class="bg-white bg-opacity-25 p-3 rounded-circle">
                            <i class="bi bi-bag-check fs-2"></i>
                        </div>
                    </div>
                </div>
                
                <div class="card-body p-4 p-md-5">
                    <div class="row g-4 mb-5">
                        <div class="col-md-4">
                            <div class="p-3 bg-light rounded-3 text-center h-100">
                                <p class="text-muted small text-uppercase fw-bold mb-1">Sipariş No</p>
                                <h5 class="mb-0">#@Model.OrderingId</h5>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="p-3 bg-light rounded-3 text-center h-100">
                                <p class="text-muted small text-uppercase fw-bold mb-1">Toplam Tutar</p>
                                <h5 class="mb-0 text-success">@Model.TotalPrice.ToString("C2")</h5>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="p-3 bg-light rounded-3 text-center h-100">
                                <p class="text-muted small text-uppercase fw-bold mb-1">Durum</p>
                                <span class="badge bg-info text-dark px-3 py-2 rounded-pill">@Model.Status</span>
                            </div>
                        </div>
                    </div>

                    <div class="mb-5">
                        <h5 class="fw-bold mb-3 d-flex align-items-center">
                            <i class="bi bi-geo-alt text-primary me-2"></i>
                            Teslimat Bilgileri
                        </h5>
                        <div class="border rounded-3 p-4 bg-light bg-opacity-50">
                            <div class="row">
                                <div class="col-sm-6 mb-3 mb-sm-0">
                                    <p class="text-muted small text-uppercase fw-bold mb-1">Alıcı</p>
                                    <p class="mb-0 fw-medium">@Model.FirstName @Model.LastName</p>
                                    <p class="mb-0 text-muted">@Model.PhoneNumber</p>
                                </div>
                                <div class="col-sm-6">
                                    <p class="text-muted small text-uppercase fw-bold mb-1">Adres</p>
                                    <p class="mb-0">@Model.AddressDetail</p>
                                    <p class="mb-0">@Model.District / @Model.City</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="d-grid">
                        <a asp-controller="Payment" asp-action="Index" asp-route-orderId="@Model.OrderingId" 
                           class="btn btn-primary btn-lg py-3 rounded-pill fw-bold shadow-sm hover-lift">
                            Ödemeye Geç
                            <i class="bi bi-arrow-right ms-2"></i>
                        </a>
                    </div>
                </div>
            </div>
            
            <div class="text-center mt-4">
                <a href="/" class="text-decoration-none text-muted">
                    <i class="bi bi-chevron-left small me-1"></i> Alışverişe Devam Et
                </a>
            </div>
        </div>
    </div>
</div>

<style>
    .hover-lift {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .hover-lift:hover {
        transform: translateY(-2px);
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
    }
    .rounded-4 { border-radius: 1rem !important; }
</style>
