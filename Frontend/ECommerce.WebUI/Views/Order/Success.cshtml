@{
    ViewData["Title"] = "Sipariş Onayı";
}

<div class="order-success-wrapper py-5">
    <div class="card border-0 shadow-lg order-success-card mx-auto">
        <div class="card-body p-4 p-md-5 text-center">
            <div class="success-icon mb-4">✓</div>
            <h1 class="fw-bold mb-3">Siparişiniz Başarıyla Alındı</h1>
            <p class="text-muted mb-4">
                Ödemeniz onaylandı ve siparişiniz hazırlık sürecine geçti.
                Kısa süre içinde sipariş detaylarınızı e-posta adresinize ileteceğiz.
            </p>

            <div class="d-flex flex-column flex-sm-row justify-content-center gap-2">
                <a asp-controller="Home" asp-action="Index" class="btn btn-primary px-4 py-2">
                    Alışverişe Devam Et
                </a>
                <a asp-controller="Order" asp-action="Create" class="btn btn-outline-secondary px-4 py-2">
                    Yeni Sipariş Oluştur
                </a>
            </div>
        </div>
    </div>
</div>

<style>
    .order-success-wrapper {
        min-height: 70vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #f8fbff 0%, #eef3ff 100%);
        border-radius: 1rem;
    }

    .order-success-card {
        max-width: 700px;
        border-radius: 1rem;
    }

    .success-icon {
        width: 84px;
        height: 84px;
        margin: 0 auto;
        border-radius: 50%;
        display: grid;
        place-items: center;
        font-size: 2rem;
        font-weight: 700;
        color: #fff;
        background: linear-gradient(135deg, #28a745, #1f8f3f);
        box-shadow: 0 10px 25px rgba(40, 167, 69, 0.35);
    }
</style>
