@model Frontend.DtosLayer.ProductsDto.GetProductByIdDto

@{
    ViewData["Title"] = "Details";
    Layout = "~/Views/UILayout/_Layout.cshtml";
    //id yi al
    var productId = Model?.ProductId;
}

<h1>Details</h1>
<div class="container-fluid">
    <div class="row px-xl-5">
        <div class="col-12">
            <nav class="breadcrumb bg-light mb-30">
                <a class="breadcrumb-item text-dark" href="#">Home</a>
                <a class="breadcrumb-item text-dark" href="#">Shop</a>
                <span class="breadcrumb-item active">Shop Detail</span>
            </nav>
        </div>
    </div>
</div>


<div class="container-fluid pb-5">
    <div class="row px-xl-5">
        @* ID parametresini Component'lere gönderiyoruz *@
        @await Component.InvokeAsync("ProductDetailImageSliderComponentPartial", new { id = productId })

        @await Component.InvokeAsync("ProductDetailFeatureComponentPartial", new { id = productId })
    </div>
    <div class="row px-xl-5">
        <div class="col">
            <div class="bg-light p-30">
                <div class="nav nav-tabs mb-4">
                    <a class="nav-item nav-link text-dark active" data-toggle="tab" href="#tab-pane-1">Description</a>
                    <a class="nav-item nav-link text-dark" data-toggle="tab" href="#tab-pane-2">Information</a>
                    <a class="nav-item nav-link text-dark" data-toggle="tab" href="#tab-pane-3">Reviews (0)</a>
                </div>
                <div class="tab-content">
                    @await Component.InvokeAsync("ProductDetailDescriptionComponentPartial", new { id = productId })

                    @await Component.InvokeAsync("ProductDetailInformationComponentPartial", new { id = productId })

                    @await Component.InvokeAsync("ProductDetailReviewComponentPartial", new { id = productId })
                </div>
            </div>
        </div>
    </div>
</div>
