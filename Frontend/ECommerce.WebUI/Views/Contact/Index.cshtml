@model Frontend.DtosLayer.ContactDto.CreateContactDto

@{
    ViewData["Title"] = "İletişim";
    Layout = "~/Views/UILayout/_Layout.cshtml";
}

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="https://code.jquery.com/jquery-3.4.1.min.js"></script>

<div class="container-fluid">
    <div class="row px-xl-5">
        <div class="col-12">
            <nav class="breadcrumb bg-light mb-30">
                <a class="breadcrumb-item text-dark" href="/Default/Index">Anasayfa</a>
                <span class="breadcrumb-item active">İletişim</span>
            </nav>
        </div>
    </div>
</div>
<div class="container-fluid">
    <h2 class="section-title position-relative text-uppercase mx-xl-5 mb-4"><span class="bg-secondary pr-3">Bize Ulaşın</span></h2>
    <div class="row px-xl-5">
        <div class="col-lg-7 mb-5">
            <div class="contact-form bg-light p-30">

                @if (TempData["ContactSuccess"] != null)
                {
                    <script>
                        Swal.fire({
                            title: 'Başarılı!',
                            // Html.Raw kullanarak karakterlerin bozulmasını engelliyoruz
                            text: '@Html.Raw(TempData["ContactSuccess"])',
                            icon: 'success',
                            confirmButtonText: 'Tamam',
                            confirmButtonColor: '#FFD333' // Temana uygun sarı buton rengi
                        });
                    </script>
                }

                <form method="post" asp-action="Index" asp-controller="Contact">
                    <div class="control-group mb-3">
                        <input type="text" class="form-control" asp-for="NameSurname" placeholder="Adınız Soyadınız"
                               required="required" />
                    </div>
                    <div class="control-group mb-3">
                        <input type="email" class="form-control" asp-for="Email" placeholder="E-Posta Adresiniz"
                               required="required" />
                    </div>
                    <div class="control-group mb-3">
                        <input type="text" class="form-control" asp-for="Subject" placeholder="Konu"
                               required="required" />
                    </div>
                    <div class="control-group mb-3">
                        <textarea class="form-control" rows="8" asp-for="Message" placeholder="Mesajınız"
                                  required="required"></textarea>
                    </div>
                    <div>
                        <button class="btn btn-primary py-2 px-4" type="submit" id="sendMessageButton">
                            Mesajı Gönder
                        </button>
                    </div>
                </form>
            </div>
        </div>
        <div class="col-lg-5 mb-5">
            <div class="bg-light p-30 mb-30">
                <iframe style="width: 100%; height: 250px;"
                        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3009.2851586541585!2d28.931448376550742!3d41.04092571732549!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x14cab03248698115%3A0xc3f982959da74844!2zSXPPhGFuYnVsIFRpY2FyZXQgw5xuaXZlcnNpdGVzaQ!5e0!3m2!1str!2str!4v1710000000000!5m2!1str!2str"
                        frameborder="0" style="border:0;" allowfullscreen="" aria-hidden="false" tabindex="0"></iframe>
            </div>
            <div class="bg-light p-30 mb-3">
                <p class="mb-2"><i class="fa fa-map-marker-alt text-primary mr-3"></i>Sütlüce, İmrahor Cd. No:88, Beyoğlu/İstanbul</p>
                <p class="mb-2"><i class="fa fa-envelope text-primary mr-3"></i>info@ticaret.edu.tr</p>
                <p class="mb-2"><i class="fa fa-phone-alt text-primary mr-3"></i>444 0 413</p>
            </div>
        </div>
    </div>
</div>