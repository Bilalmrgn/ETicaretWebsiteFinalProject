@if (TempData["LoginRequired"] != null)
{
    <script>
        Swal.fire({
            title: 'Oturum Açmanız Gerekiyor!',
            text: 'Favorilere ürün ekleyebilmek veya silebilmek için lütfen önce giriş yapınız.',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#FFD333',
            cancelButtonColor: '#3D464D',
            confirmButtonText: 'Giriş Yap',
            cancelButtonText: 'Kapat',
            background: '#F5F5F5',
            color: '#3D464D'
        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '/Login/Index';
            }
        });
    </script>
}