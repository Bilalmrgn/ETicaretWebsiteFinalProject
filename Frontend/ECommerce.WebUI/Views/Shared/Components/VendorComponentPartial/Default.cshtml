@model List<Frontend.DtosLayer.BrandDto.ResultBrandDto>

<div class="container-fluid py-5">
    <div class="row px-xl-5">
        <div class="col">
            <div class="owl-carousel vendor-carousel">
                @if (Model != null)
                {
                    @foreach (var item in Model)
                    {
                      
                        <div class="bg-light p-4">
                            <img src="@item.BrandImageUrl" alt="@item.BrandName">
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>