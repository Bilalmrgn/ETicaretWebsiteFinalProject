<div class="container-fluid">
    <div class="row align-items-center bg-light py-3 px-xl-5 d-none d-lg-flex">
        <div class="col-lg-4">
            <a href="/" class="text-decoration-none">
                <span class="h1 text-uppercase text-primary bg-dark px-2"><i class="fa fa-bolt"></i> Volt</span>
                <span class="h1 text-uppercase text-light bg-primary px-2 ml-n1">Tech</span>
            </a>
        </div>
        <div class="col-lg-4 col-6 text-left">
            <form action="">
                <div class="input-group">
                    <input type="text" class="form-control" placeholder="Ürün ara...">
                    <div class="input-group-append">
                        <span class="input-group-text bg-transparent text-primary">
                            <i class="fa fa-search"></i>
                        </span>
                    </div>
                </div>
            </form>
        </div>

        <div class="col-lg-4 col-6 text-right">
            <div class="d-inline-flex align-items-center">
                @if (User.Identity.IsAuthenticated && User.IsInRole("Admin"))
                {
                    <li class="nav-item list-unstyled mr-3">
                        <a class="nav-link text-danger font-weight-bold" asp-area="Admin" asp-controller="AdminHome" asp-action="Index">
                            <i class="fas fa-user-shield"></i> Yönetim Paneli
                        </a>
                    </li>
                }
                @if (User.Identity.IsAuthenticated)
                {
                    <style>
                        .user-dropdown-custom {
                            border: none;
                            border-radius: 12px;
                            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
                            padding: 10px;
                            min-width: 200px;
                            background: rgba(255, 255, 255, 0.98);
                            transform: translateY(10px);
                            transition: all 0.3s ease;
                        }
                        .dropdown-item-custom {
                            border-radius: 8px;
                            padding: 10px 15px;
                            margin-bottom: 2px;
                            transition: all 0.2s ease;
                            display: flex;
                            align-items: center;
                            color: #333;
                            font-weight: 500;
                        }
                        .dropdown-item-custom:hover {
                            background: #f8f9fa;
                            color: var(--electric-primary);
                            transform: translateX(5px);
                        }
                        .dropdown-item-custom i {
                            width: 25px;
                            color: var(--electric-primary);
                        }
                    </style>
                    <div class="btn-group ml-3">
                        <button type="button" class="btn btn-sm btn-dark rounded-pill px-3 dropdown-toggle d-flex align-items-center" data-toggle="dropdown">
                            <div class="bg-primary rounded-circle mr-2 d-flex align-items-center justify-content-center" style="width: 25px; height: 25px;">
                                <i class="fa fa-user text-dark" style="font-size: 12px;"></i>
                            </div>
                            <span class="text-white">@(User.Identity.Name ?? "Hesabım")</span>
                        </button>
                        <div class="dropdown-menu dropdown-menu-right user-dropdown-custom">
                            <div class="px-3 py-2 border-bottom mb-2">
                                <p class="small text-muted mb-0">Hoş Geldiniz,</p>
                                <p class="font-weight-bold mb-0">@User.Identity.Name</p>
                            </div>
                            <a asp-controller="AccountSettings" asp-action="Index" class="dropdown-item-custom">
                                <i class="fas fa-cog"></i> Hesap Ayarları
                            </a>
                            <a href="/Basket/Index" class="dropdown-item-custom">
                                <i class="fas fa-shopping-cart"></i> Sepetim
                            </a>
                            <a href="/Favorite/Index" class="dropdown-item-custom">
                                <i class="fas fa-heart"></i> Favorilerim
                            </a>
                            <div class="dropdown-divider"></div>
                            <a href="/Login/LogOut" class="dropdown-item-custom text-danger">
                                <i class="fas fa-sign-out-alt text-danger"></i> Çıkış Yap
                            </a>
                        </div>
                    </div>
                }
                else
                {
                    <a href="~/Login/Index" class="btn btn-sm btn-light border mr-2 font-weight-bold">
                        <i class="fa fa-sign-in-alt text-primary mr-1"></i> Giriş Yap
                    </a>
                    <a href="/Register/Index" class="btn btn-sm btn-primary font-weight-bold">
                        <i class="fa fa-user-plus text-dark mr-1"></i> Kayıt Ol
                    </a>
                }
            </div>
        </div>
    </div>
</div>