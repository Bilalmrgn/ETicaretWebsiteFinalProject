@model List<Frontend.DtosLayer.ProductImageDto.GetByIdProductImageDto>

<div class="col-lg-5 mb-30">
    <div id="product-carousel" class="carousel slide" data-ride="carousel">
        <div class="carousel-inner bg-light">
            @{
                int itemIndex = 0;
            }

            @foreach (var item in Model)
            {
                @foreach (var imageUrl in item.Images)
                {
                    <div class="carousel-item @(itemIndex == 0 ? "active" : "")">
                        <img class="w-100 h-100" src="@imageUrl" alt="Product Image">
                    </div>
                    itemIndex++;
                }
            }

            @if (itemIndex == 0)
            {
                <div class="carousel-item active">
                    <img class="w-100 h-100" src="/WebsiteTemplate/img/default-product.jpg" alt="No Image">
                </div>
            }
        </div>

        @if (itemIndex > 1)
        {
            <a class="carousel-control-prev" href="#product-carousel" data-slide="prev">
                <i class="fa fa-2x fa-angle-left text-dark"></i>
            </a>
            <a class="carousel-control-next" href="#product-carousel" data-slide="next">
                <i class="fa fa-2x fa-angle-right text-dark"></i>
            </a>
        }
    </div>
</div>