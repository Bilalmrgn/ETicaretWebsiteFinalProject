@model Frontend.DtosLayer.ProductDetailDto.GetByIdProductDetailDTOs

<div class="tab-pane fade show active" id="tab-pane-1">
    <h4 class="mb-3">Ürün Açıklaması</h4>
    @if (Model == null || string.IsNullOrWhiteSpace(Model.ProductDetailDescription))
    {
        <p class="text-muted">Bu ürün için henüz bir açıklama girilmemiştir.</p>
    }
    else
    {
        <p>@Model.ProductDetailDescription</p>
    }
</div>