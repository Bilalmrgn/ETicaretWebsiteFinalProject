@model Frontend.DtosLayer.ProductDetailDto.GetByIdProductDetailDTOs
<div class="tab-pane fade" id="tab-pane-2">
    <h4 class="mb-3">Additional Information</h4>
    @if (Model == null || string.IsNullOrWhiteSpace(Model.ProductDetailInformation))
    {
        <p class="text-muted">Ek bilgi bulunmuyor.</p>
    }
    else
    {
        <p>@Model.ProductDetailInformation</p>    
    }
</div>