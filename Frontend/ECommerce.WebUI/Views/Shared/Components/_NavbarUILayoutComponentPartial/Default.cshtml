@model List<Frontend.DtosLayer.CategoryDto.CategoryListDto>    

<!-- Navbar Start -->
<div class="container-fluid bg-dark mb-30" style="box-shadow: 0 4px 15px rgba(0,0,0,0.2);">
    <div class="row px-xl-5">
        <div class="col-lg-3 d-none d-lg-block">
            <a class="btn d-flex align-items-center justify-content-between category-dropdown-btn w-100" data-toggle="collapse" href="#navbar-vertical" style="height: 65px; padding: 0 30px;">
                <h6 class="m-0 text-dark font-weight-bold"><i class="fa fa-bolt mr-2"></i>Kategoriler</h6>
                <i class="fa fa-angle-down text-dark"></i>
            </a>
            <nav class="collapse position-absolute navbar navbar-vertical navbar-light align-items-start p-0 bg-white category-dropdown-menu" id="navbar-vertical" style="width: calc(100% - 30px); z-index: 999;">
                <div class="navbar-nav w-100">
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <a asp-controller="Product"
                               asp-action="GetProductsByCategoryId"
                               asp-route-id="@item.CategoryId"
                               class="nav-item nav-link d-flex align-items-center">
                                <img src="@item.ImageUrl" style="width:24px; height:24px; margin-right:12px; object-fit:cover; border-radius:4px;" />
                                @item.CategoryName
                            </a>
                        }
                    }
                    else
                    {
                        <p class="nav-item nav-link text-muted">Kategori bulunamadı.</p>
                    }
                </div>
            </nav>
        </div>
        <div class="col-lg-9">
            <nav class="navbar navbar-expand-lg bg-dark navbar-dark py-3 py-lg-0 px-0">
                <a href="/" class="text-decoration-none d-block d-lg-none">
                    <span class="h1 text-uppercase text-dark bg-primary px-2"><i class="fa fa-bolt"></i> Volt</span>
                    <span class="h1 text-uppercase text-light bg-dark px-2 ml-n1">Tech</span>
                </a>
                <button type="button" class="navbar-toggler" data-toggle="collapse" data-target="#navbarCollapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse justify-content-between" id="navbarCollapse">
                    <div class="navbar-nav mr-auto py-0">
                        <a asp-controller="Home" asp-action="Index" class="nav-item nav-link">Anasayfa</a>
                        <a asp-controller="Category" asp-action="Index" class="nav-item nav-link">Kategoriler</a>
                        <a asp-controller="Product" asp-action="Index" class="nav-item nav-link">Günün Fırsatı</a>
                        <div class="nav-item dropdown">
                            <a href="#" class="nav-link dropdown-toggle" data-toggle="dropdown">Sayfalar <i class="fa fa-angle-down mt-1"></i></a>
                            <div class="dropdown-menu rounded-0 border-0 m-0" style="background-color: var(--electric-primary);">
                                <a asp-controller="Basket" asp-action="Index" class="dropdown-item text-dark font-weight-bold">Sepetim</a>
                                <a asp-controller="Basket" asp-action="Index" class="dropdown-item text-dark font-weight-bold">Ödeme İşlemleri</a>
                            </div>
                        </div>
                        <a asp-controller="Contact" asp-action="Index" class="nav-item nav-link active">İletişim</a>
                    </div>
                    <div class="navbar-nav ml-auto py-0 d-none d-lg-flex align-items-center">
                        <a href="/Favorite/Index" class="btn px-0 mr-3 position-relative">
                            <i class="fas fa-heart text-primary" style="font-size: 1.3rem;"></i>
                            <span class="badge badge-custom rounded-circle position-absolute">@ViewBag.FavoriteCount</span>
                        </a>
                        <a asp-controller="Basket" asp-action="Index" class="btn px-0 ml-3 position-relative">
                            <i class="fas fa-shopping-cart text-primary" style="font-size: 1.3rem;"></i>
                            <span class="badge badge-custom rounded-circle position-absolute">0</span>
                        </a>
                    </div>
                </div>
            </nav>
        </div>
    </div>
</div>
<!-- Navbar End -->