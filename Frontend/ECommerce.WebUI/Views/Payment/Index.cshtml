@using Frontend.DtosLayer.PaymentDtos.CreditCardDtos
@model List<ResultCreditCardDto>

@{
    ViewData["Title"] = "Ödeme Yöntemi";
    var orderId = ViewBag.OrderId;
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

<style>
    :root {
        --electric-yellow: #FACC15;
        --electric-dark: #0F172A;
        --electric-glass: rgba(255, 255, 255, 0.95);
        --electric-primary: #3b82f6;
    }

    body {
        background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
    }

    .checkout-container {
        max-width: 900px;
        margin: 40px auto;
    }

    /* Progress Bar */
    .stepper {
        display: flex;
        justify-content: space-between;
        margin-bottom: 60px;
        position: relative;
    }
    .stepper::before {
        content: "";
        position: absolute;
        top: 20px;
        left: 0;
        right: 0;
        height: 2px;
        background: #cbd5e1;
        z-index: 1;
    }
    .step {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: #fff;
        border: 2px solid #cbd5e1;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 2;
        font-weight: bold;
        color: #64748b;
        transition: all 0.3s ease;
        position: relative;
    }
    .step.active {
        border-color: var(--electric-yellow);
        background: var(--electric-yellow);
        color: var(--electric-dark);
        box-shadow: 0 0 20px rgba(250, 204, 21, 0.4);
    }
    .step.completed {
        background: var(--electric-dark);
        border-color: var(--electric-dark);
        color: var(--electric-yellow);
    }
    .step-label {
        position: absolute;
        top: 50px;
        font-size: 0.8rem;
        white-space: nowrap;
        font-weight: 700;
        color: #475569;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    /* Card Styling */
    .glass-card {
        background: var(--electric-glass);
        backdrop-filter: blur(10px);
        border-radius: 30px;
        border: 1px solid rgba(255, 255, 255, 0.8);
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.1);
        padding: 50px;
        animation: fadeInSlide 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    }

    @@keyframes fadeInSlide {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .form-title {
        color: var(--electric-dark);
        font-weight: 900;
        font-size: 2.5rem;
        letter-spacing: -1px;
        margin-bottom: 10px;
    }

    /* Card List Selection */
    .card-list {
        display: flex;
        flex-direction: column;
        gap: 15px;
        margin-bottom: 30px;
    }

    .card-option {
        position: relative;
    }

    .card-label {
        display: flex;
        align-items: center;
        padding: 25px;
        border-radius: 20px;
        border: 2px solid #f1f5f9;
        background: #f8fafc;
        cursor: pointer;
        transition: all 0.3s ease;
        position: relative;
    }

    .card-label:hover {
        border-color: var(--electric-yellow);
        background: #fff;
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(0,0,0,0.05);
    }

    .btn-check:checked + .card-label {
        border-color: var(--electric-primary);
        background: #fff;
        box-shadow: 0 10px 25px rgba(59, 130, 246, 0.15);
    }

    .check-circle {
        width: 28px;
        height: 28px;
        border-radius: 50%;
        border: 2px solid #cbd5e1;
        margin-right: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s ease;
        background: #fff;
    }

    .check-circle i {
        color: #fff;
        font-size: 0.9rem;
        display: none;
    }

    .btn-check:checked + .card-label .check-circle {
        background: var(--electric-primary);
        border-color: var(--electric-primary);
    }

    .btn-check:checked + .card-label .check-circle i {
        display: block;
    }

    .card-icon-box {
        font-size: 2.2rem;
        color: #94a3b8;
        margin-right: 25px;
    }

    .btn-check:checked + .card-label .card-icon-box {
        color: var(--electric-primary);
    }

    .card-info {
        flex-grow: 1;
    }

    .card-name {
        font-weight: 800;
        color: var(--electric-dark);
        font-size: 1.2rem;
        margin-bottom: 4px;
        display: block;
    }

    .card-meta {
        color: #64748b;
        font-size: 1rem;
        font-family: 'JetBrains Mono', monospace;
        letter-spacing: 1px;
    }

    .expire-date {
        font-weight: 700;
        color: #94a3b8;
        font-size: 1rem;
        background: #f1f5f9;
        padding: 6px 12px;
        border-radius: 8px;
    }

    /* Buttons */
    .btn-payment {
        background: var(--electric-primary);
        color: #fff;
        border: none;
        padding: 22px;
        border-radius: 20px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 2px;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        box-shadow: 0 10px 25px -5px rgba(59, 130, 246, 0.3);
        cursor: pointer;
    }

    .btn-payment:hover {
        background: #2563eb;
        transform: translateY(-5px);
        box-shadow: 0 20px 30px -10px rgba(59, 130, 246, 0.5);
        color: #fff;
    }

    .btn-add-card {
        background: #fff;
        color: var(--electric-dark);
        border: 2px solid var(--electric-dark);
        padding: 18px;
        border-radius: 20px;
        font-weight: 800;
        transition: all 0.3s ease;
        text-decoration: none;
        display: block;
        text-align: center;
    }

    .btn-add-card:hover {
        background: var(--electric-dark);
        color: var(--electric-yellow);
    }

    .empty-state {
        text-align: center;
        padding: 60px 0;
    }

    .empty-icon {
        font-size: 6rem;
        color: #e2e8f0;
        margin-bottom: 25px;
    }
</style>

<div class="container pb-5">
    <div class="checkout-container">
        <!-- Stepper -->
        <div class="stepper">
            <div class="step completed">
                <i class="fa-solid fa-check"></i>
                <span class="step-label">Adres</span>
            </div>
            <div class="step active">
                2
                <span class="step-label">Ödeme</span>
            </div>
            <div class="step">
                3
                <span class="step-label" style="opacity: 0.5;">Onay</span>
            </div>
        </div>

        <!-- Main Card -->
        <div class="glass-card">
            <div class="text-center mb-5">
                <h1 class="form-title">Ödeme Yöntemi</h1>
                <p class="text-muted fs-5">Kaydedilmiş bir kartınızı seçin veya yeni bir kartla devam edin.</p>
            </div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger border-0 shadow-sm mb-4 rounded-4 d-flex align-items-center p-3" role="alert">
                    <i class="fa-solid fa-circle-exclamation me-3 fs-4"></i>
                    <div asp-validation-summary="ModelOnly" class="fw-bold"></div>
                </div>
            }

            @if (Model != null && Model.Any())
            {
                <form asp-controller="Payment" asp-action="Index" method="post">
                    <input type="hidden" name="OrderId" value="@orderId" />
                    <input type="hidden" name="Email" value="@ViewBag.Email" />
                    <input type="hidden" name="TotalPrice" value="@ViewBag.TotalPrice" />

                    <h6 class="text-uppercase text-muted fw-bold small mb-4 ls-wide" style="letter-spacing: 2px;">KAYITLI KARTLARINIZ</h6>

                    <div class="card-list">
                        @foreach (var card in Model)
                        {
                            <div class="card-option">
                                <input type="radio" name="CreditCardId" id="card_@card.CreditCardId" value="@card.CreditCardId" class="btn-check" required>
                                <label class="card-label" for="card_@card.CreditCardId">
                                    <div class="check-circle">
                                        <i class="fa-solid fa-check"></i>
                                    </div>
                                    <div class="card-icon-box">
                                        <i class="fa-solid fa-credit-card"></i>
                                    </div>
                                    <div class="card-info">
                                        <span class="card-name">@card.CardHolderName</span>
                                        <span class="card-meta">
                                            @{
                                                var maskedNumber = card.CardNumber.Length >= 12
                                                ? "**** **** **** " + card.CardNumber.Substring(card.CardNumber.Length - 4)
                                                : card.CardNumber;
                                            }
                                            @maskedNumber
                                        </span>
                                    </div>
                                    <div class="expire-date">
                                        @card.ExpireDate
                                    </div>
                                </label>
                            </div>
                        }
                    </div>

                    <div class="d-grid gap-4 mt-5">
                        <button type="submit" class="btn-payment">
                            <i class="fa-solid fa-shield-halved me-2"></i> Güvenli Ödeme Yap
                        </button>
                        
                        <div class="text-center py-2">
                            <span class="text-muted fw-bold small" style="letter-spacing: 3px;">VEYA</span>
                        </div>

                        <a asp-action="AddCard" asp-controller="Payment" class="btn btn-add-card">
                            <i class="fa-solid fa-plus me-2"></i> Yeni Kart Ekle
                        </a>
                    </div>
                </form>
            }
            else
            {
                <div class="empty-state">
                    <div class="empty-icon">
                        <i class="fa-solid fa-credit-card"></i>
                    </div>
                    <h3 class="fw-bold text-dark mb-3">Kayıtlı Kart Bulunamadı</h3>
                    <p class="text-muted mb-5 px-5">Henüz sistemimize kayıtlı bir kredi kartınız yok. Ödeme yapabilmek için lütfen bir kart ekleyin.</p>
                    <a asp-action="AddCard" class="btn-payment px-5 text-decoration-none d-inline-block">
                        <i class="fa-solid fa-plus me-2"></i> Yeni Kart Ekle
                    </a>
                </div>
            }

            <div class="mt-5 pt-4 border-top text-center">
                <div class="d-flex justify-content-center gap-4 mb-3">
                    <i class="fa-brands fa-cc-visa fs-1 text-primary opacity-50"></i>
                    <i class="fa-brands fa-cc-mastercard fs-1 text-danger opacity-50"></i>
                    <i class="fa-brands fa-cc-amex fs-1 text-info opacity-50"></i>
                </div>
                <p class="text-muted small mb-0">
                    <i class="fa-solid fa-lock me-1"></i> Tüm ödemeleriniz banka düzeyinde 256-bit SSL ile korunmaktadır.
                </p>
            </div>
        </div>
    </div>
</div>
