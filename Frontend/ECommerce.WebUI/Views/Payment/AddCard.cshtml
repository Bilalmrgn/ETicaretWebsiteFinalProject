@model Frontend.DtosLayer.PaymentDtos.CreditCardDtos.CreateCreditCardDto

@{
    ViewData["Title"] = "Yeni Kart Ekle";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-header bg-white border-0 py-4 px-4">
                    <div class="d-flex align-items-center">
                        <a asp-action="Index" class="btn btn-link text-dark p-0 me-3">
                            <i class="bi bi-arrow-left fs-4"></i>
                        </a>
                        <h2 class="h4 mb-0 fw-bold">Yeni Kart Ekle</h2>
                    </div>
                </div>

                <div class="card-body p-4 p-md-5 pt-2">
                    <!-- Visual Card Representation -->
                    <div class="credit-card-visual mb-5 position-relative">
                        <div class="bg-gradient bg-primary rounded-4 p-4 text-white shadow-lg" style="height: 200px; background: linear-gradient(135deg, #0d6efd 0%, #0a58ca 100%);">
                            <div class="d-flex justify-content-between align-items-start mb-4">
                                <i class="bi bi-cpu-fill fs-2 text-warning opacity-75"></i>
                                <div class="fs-4 fw-bold italic">VISA</div>
                            </div>
                            <div class="card-number-display fs-3 fw-bold mb-4 tracking-widest" id="previewNumber">
                                **** **** **** ****
                            </div>
                            <div class="d-flex justify-content-between align-items-end">
                                <div>
                                    <div class="small opacity-75 mb-1">Kart Sahibi</div>
                                    <div class="fw-bold" id="previewName">AD SOYAD</div>
                                </div>
                                <div>
                                    <div class="small opacity-75 mb-1">SKT</div>
                                    <div class="fw-bold"><span id="previewMonth">MM</span>/<span id="previewYear">YY</span></div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <form asp-action="AddCard" method="post">
                        <div class="mb-4">
                            <label asp-for="CardHolderName" class="form-label fw-bold text-muted small text-uppercase mb-2">Kart Üzerindeki İsim</label>
                            <input asp-for="CardHolderName" id="inputName" class="form-control form-control-lg rounded-3 bg-light border-0 px-3" placeholder="AD SOYAD" required oninput="updatePreview()">
                            <span asp-validation-for="CardHolderName" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="CardNumber" class="form-label fw-bold text-muted small text-uppercase mb-2">Kart Numarası</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0 rounded-start-3">
                                    <i class="bi bi-credit-card text-muted"></i>
                                </span>
                                <input asp-for="CardNumber" id="inputNumber" class="form-control form-control-lg bg-light border-0 rounded-end-3 px-3" placeholder="0000 0000 0000 0000" maxlength="19" required oninput="updatePreview()">
                            </div>
                            <span asp-validation-for="CardNumber" class="text-danger small"></span>
                        </div>

                        <div class="row mb-5">
                            <div class="col-md-7">
                                <label class="form-label fw-bold text-muted small text-uppercase mb-2">Son Kullanma Tarihi</label>
                                <div class="row g-2">
                                    <div class="col-6">
                                        <input asp-for="ExpireMonth" id="inputMonth" class="form-control form-control-lg rounded-3 bg-light border-0 text-center" placeholder="AA" maxlength="2" required oninput="updatePreview()">
                                    </div>
                                    <div class="col-6">
                                        <input asp-for="ExpireYear" id="inputYear" class="form-control form-control-lg rounded-3 bg-light border-0 text-center" placeholder="YY" maxlength="2" required oninput="updatePreview()">
                                    </div>
                                </div>
                                <div class="d-flex gap-2">
                                    <span asp-validation-for="ExpireMonth" class="text-danger small"></span>
                                    <span asp-validation-for="ExpireYear" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-5">
                                <label asp-for="CVV" class="form-label fw-bold text-muted small text-uppercase mb-2">CVV</label>
                                <input asp-for="CVV" class="form-control form-control-lg rounded-3 bg-light border-0 text-center" placeholder="000" maxlength="3" required>
                                <span asp-validation-for="CVV" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-lg py-3 rounded-pill fw-bold shadow-sm hover-lift">
                                <i class="bi bi-check-circle me-2"></i>
                                Kartı Güvenle Kaydet
                            </button>
                        </div>
                    </form>
                </div>
            </div>
            
            <div class="text-center mt-4">
                <p class="text-muted small mb-0">
                    <i class="bi bi-shield-lock-fill text-success me-1"></i>
                    Bilgileriniz banka düzeyinde güvenlik protokolleri ile korunmaktadır.
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function updatePreview() {
            const name = document.getElementById('inputName').value;
            const number = document.getElementById('inputNumber').value;
            const month = document.getElementById('inputMonth').value;
            const year = document.getElementById('inputYear').value;

            document.getElementById('previewName').innerText = name || 'AD SOYAD';
            
            // Format card number with spaces for preview
            let formattedNumber = number.replace(/\s?/g, '').replace(/(\d{4})/g, '$1 ').trim();
            document.getElementById('previewNumber').innerText = formattedNumber || '**** **** **** ****';
            
            document.getElementById('previewMonth').innerText = month || 'MM';
            document.getElementById('previewYear').innerText = year || 'YY';
            
            // Auto format input number
            if (number.length > 0) {
                let v = number.replace(/\s+/g, '').replace(/[^0-9]/gi, '');
                let matches = v.match(/\d{4,16}/g);
                let match = matches && matches[0] || '';
                let parts = [];
                for (let i=0, len=match.length; i<len; i+=4) {
                    parts.push(match.substring(i, i+4));
                }
                if (parts.length) {
                    document.getElementById('inputNumber').value = parts.join(' ');
                }
            }
        }
    </script>
}

<style>
    .rounded-4 { border-radius: 1rem !important; }
    .tracking-widest { letter-spacing: 0.15em; }
    .hover-lift {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .hover-lift:hover {
        transform: translateY(-2px);
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
    }
    .credit-card-visual {
        perspective: 1000px;
    }
</style>
