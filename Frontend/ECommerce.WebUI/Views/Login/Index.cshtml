@model Frontend.DtosLayer.LoginDto.LoginDto

@{
    ViewData["Title"] = "Giriş Yap";
    Layout = "~/Views/UILayout/_Layout.cshtml";
}

<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

<style>
    /* Kart Sabit ve Vakur Duruş */
    .login-card {
        border: none;
        border-radius: 24px;
        background: #ffffff;
        box-shadow: 0 15px 35px rgba(0,0,0,0.06);
        overflow: hidden;
        max-width: 900px;
        margin: auto;
    }

    /* Sol Görsel Alanı - Daha Soft Bir Sarı */
    .login-side-panel {
        background-color: #ffd333;
        color: #3d464d;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        padding: 40px;
        text-align: center;
    }

    /* Input Tasarımı - Apple Style Minimalist */
    .input-group-custom {
        border-radius: 12px;
        border: 2px solid #e9ecef;
        background-color: #f8f9fa;
        transition: all 0.3s ease;
        overflow: hidden;
    }

    .input-group-custom:focus-within {
        border-color: #3d464d;
        background-color: #fff;
        box-shadow: 0 0 0 0.2rem rgba(61, 70, 77, 0.25);
    }

    .input-group-custom .input-group-text {
        border: none;
        background: transparent;
        padding-left: 15px;
        color: #3d464d;
    }

    .input-group-custom .form-control {
        border: none;
        background: transparent;
        padding: 12px 15px 12px 0;
        box-shadow: none;
        color: #3d464d;
        font-weight: 500;
    }

    /* Login Butonu */
    .btn-login {
        background: #3d464d;
        color: #ffd333;
        border: none;
        border-radius: 12px;
        padding: 14px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: all 0.3s ease;
        box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    }

        .btn-login:hover {
            background: #2c343a;
            color: #fff;
            transform: translateY(-2px);
            box-shadow: 0 6px 12px rgba(0,0,0,0.15);
        }

    .btn-admin {
        border-radius: 12px;
        padding: 12px;
        letter-spacing: 1px;
        color: #3d464d;
        border: 2px solid #3d464d;
        background: transparent;
        font-weight: 700;
        text-transform: uppercase;
        transition: all 0.3s ease;
    }

        .btn-admin:hover {
            background: #3d464d;
            color: #ffd333 !important;
            transform: translateY(-2px);
            box-shadow: 0 6px 12px rgba(0,0,0,0.15);
        }

    .text-muted-custom {
        color: #86868b;
        font-size: 0.9rem;
    }

    .link-custom {
        color: #3d464d;
        font-weight: 600;
        text-decoration: none;
    }

        .link-custom:hover {
            text-decoration: underline;
        }
</style>

<div class="container py-5 mt-5">
    <div class="login-card row g-0">
        <div class="col-lg-5 login-side-panel d-none d-lg-flex">
            <i class="fas fa-lock fa-4x mb-4"></i>
            <h2 class="fw-bold">Tekrar Hoş Geldin</h2>
            <p class="opacity-75">MultiShop dünyasına güvenli bir giriş yap ve kaldığın yerden devam et.</p>
            <div class="mt-4">
                <p class="mb-1 small">Henüz hesabın yok mu?</p>
                <a href="/Register/Index" class="btn btn-outline-dark btn-sm rounded-pill px-4 fw-bold">Kayıt Ol</a>
            </div>
        </div>

        <div class="col-lg-7 p-4 p-md-5 bg-white">
            <div class="mb-5 text-center text-lg-start">
                <h3 class="fw-bold text-dark mb-2">Giriş Yap</h3>
                <p class="text-muted-custom">Lütfen kayıtlı e-posta adresinizi ve şifrenizi giriniz.</p>
            </div>

            <form asp-action="Index" asp-controller="Login" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 small"></div>

                <div class="mb-4">
                    <label class="form-label fw-bold small text-secondary">E-POSTA ADRESİ</label>
                    <div class="input-group input-group-custom">
                        <span class="input-group-text"><i class="fas fa-envelope"></i></span>
                        <input type="email" asp-for="Email" class="form-control" placeholder="mail@example.com">
                    </div>
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <div class="d-flex justify-content-between">
                        <label class="form-label fw-bold small text-secondary">ŞİFRE</label>
                        <a href="/Login/ForgotPassword" class="link-custom small">Şifremi Unuttum?</a>
                    </div>
                    <div class="input-group input-group-custom">
                        <span class="input-group-text"><i class="fas fa-key"></i></span>
                        <input type="password" asp-for="Password" class="form-control" placeholder="••••••••">
                    </div>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="mb-4 form-check">
                    <input type="checkbox" asp-for="RememberMe" class="form-check-input" id="rememberCheck">
                    <label class="form-check-label text-muted-custom small" for="rememberCheck">Oturumu açık tut (Beni Hatırla)</label>
                </div>

                <button type="submit" class="btn btn-login w-100 shadow-sm mt-2 mb-3">
                    <i class="fas fa-sign-in-alt me-2"></i>Giriş Yap
                </button>

                <a asp-area="Admin" asp-controller="AdminLogin" asp-action="Index" class="btn btn-admin w-100 d-flex align-items-center justify-content-center">
                    <i class="fas fa-user-shield me-2"></i>Yönetici Girişi
                </a>

                <div class="mt-4 text-center d-lg-none">
                    <span class="text-muted-custom small">Hesabın yok mu? <a href="/Register/Index" class="link-custom">Kayıt Ol</a></span>
                </div>
            </form>
        </div>
    </div>
</div>

@* Scriptler *@
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
<script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>