@* Formu Post metoduna, Login action'ına yönlendiriyoruz *@
<form asp-action="Login" asp-controller="AdminLogin" asp-area="Admin" method="post">

    <div class="login-header">
        <i class="fas fa-user-shield mb-3"></i>
        <h3>Yönetim Paneli</h3>
        <p class="text-muted">Güvenli giriş için aşağıdaki butona tıklayınız</p>
    </div>

    @* Bilgi Notu: Authorization Code akışında şifre burada girilmez *@
    <div class="alert alert-info small border-0">
        <i class="fas fa-info-circle me-1"></i>
        Giriş işlemleri güvenli kimlik doğrulama sunucusu üzerinden gerçekleştirilecektir.
    </div>

    <button type="submit" class="btn btn-primary btn-login w-100 mb-3 text-white">
        <i class="fas fa-sign-in-alt me-2"></i> Kimlik Doğrula ve Giriş Yap
    </button>

    <div class="text-center">
        <a href="/" class="text-muted small text-decoration-none">
            <i class="fas fa-arrow-left me-1"></i> Siteye Dön
        </a>
    </div>
</form>