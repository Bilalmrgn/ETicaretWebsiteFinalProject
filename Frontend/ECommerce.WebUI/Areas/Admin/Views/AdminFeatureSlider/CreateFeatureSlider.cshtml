@model Frontend.DtosLayer.SliderFeatureDto.CreateFeatureSliderDto

@{
    ViewData["Title"] = "Yeni Slider Ekle";
    Layout = "~/Areas/Admin/Views/AdminLayout/_AdminLayout.cshtml";
}

<h3>Yeni Slider Ekle</h3>

<form method="post">

    <div class="mb-3">
        <label>Slider Başlığı</label>
        <input type="text" asp-for="Title" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Slider Görsel Url</label>
        <input type="text" asp-for="ImageUrl" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Slider Açıklaması</label>
        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
    </div>

    <div class="mb-3">
        <label>Durum</label>
        <select asp-for="Status" class="form-control">
            <option value="true">Aktif</option>
            <option value="false">Pasif</option>
        </select>
    </div>

    <button type="submit" class="btn btn-success">
        Kaydet
    </button>

    <a asp-action="Index"
       asp-controller="AdminFeatureSlider"
       asp-area="Admin"
       class="btn btn-secondary">
        Geri
    </a>

</form>