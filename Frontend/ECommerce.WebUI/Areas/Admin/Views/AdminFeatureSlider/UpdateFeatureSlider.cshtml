@model Frontend.DtosLayer.SliderFeatureDto.UpdateFeatureSliderDto

@{
    ViewData["Title"] = "Slider Güncelle";
    Layout = "~/Areas/Admin/Views/AdminLayout/_AdminLayout.cshtml";
}

<div class="container-fluid">
    <div class="card-style mb-30">
        <h3 class="mb-25">Öne Çıkan Görseli Güncelle</h3>

        <form asp-area="Admin"
              asp-controller="AdminFeatureSlider"
              asp-action="UpdateFeatureSlider"
              method="post">

            <input type="hidden" asp-for="FeatureSliderId" />

            <div class="mb-3">
                <label class="form-label">Başlık</label>
                <input type="text" asp-for="Title" class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">Görsel URL</label>
                <input type="text" asp-for="ImageUrl" class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">Açıklama</label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
            </div>

            <div class="mb-3">
                <label class="form-label">Görünürlük Durumu</label>
                <select asp-for="Status" class="form-control">
                    <option value="true">Aktif</option>
                    <option value="false">Pasif</option>
                </select>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary">
                    <i class="lni lni-reload"></i> Güncelle
                </button>

                <a asp-action="Index"
                   asp-controller="AdminFeatureSlider"
                   asp-area="Admin"
                   class="btn btn-secondary">
                    <i class="lni lni-arrow-left"></i> Geri Dön
                </a>
            </div>
        </form>
    </div>
</div>