@model Frontend.DtosLayer.CategoryDto.CreateCategoryDto
@{
    ViewData["Title"] = "CreateCategory";
    Layout = "~/Areas/Admin/Views/AdminLayout/_AdminLayout.cshtml";
}


<h3>Kategori Ekle</h3>

<form method="post">

    <div class="mb-3">
        <label>Kategori Adı</label>
        <input type="text" asp-for="CategoryName" class="form-control" />
    </div>

    <button class="btn btn-success">Kaydet</button>
    <a asp-action="CreateCategory" asp-controller="Category" asp-area="Admin" class="btn btn-secondary">Geri</a>

</form>

