@model List<Frontend.DtosLayer.ProductsDto.ProductDetailDto>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Areas/Admin/Views/AdminLayout/_AdminLayout.cshtml";
}

<style>
    @@media (min-width: 992px) {
        .col-lg-6 {
            flex: 0 0 auto !important;
            width: 100% !important;
        }
    }
</style>

<h1>Ürün Detayları</h1>

<div class="col-lg-6">
    <div class="card-style mb-30">

        <div class="d-flex justify-content-between align-items-center mb-10">

            <h6 class="mb-10">Ürün Detayları</h6>

            <a asp-area="Admin"
               asp-controller="ProductDetail"
               asp-action="CreateProductDetail"
               class="btn btn-primary">
                + Ürün Detayı Ekle
            </a>

        </div>

        <p class="text-sm mb-20">
            Ürün detaylarının listelendiği tablo.
        </p>

        <div class="table-wrapper table-responsive">

            <table class="table striped-table">

                <thead>
                    <tr>
                        <th>
                            <h6>Bilgi</h6>
                        </th>

                        <th>
                            <h6>Açıklama</h6>
                        </th>

                        <th>
                            <h6>Ürün Id</h6>
                        </th>

                        <th>
                            <h6>Sil</h6>
                        </th>

                        <th>
                            <h6>Güncelle</h6>
                        </th>
                    </tr>
                </thead>

                <tbody>

                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>

                                <td>
                                    <p>@item.ProductDetailInformation</p>
                                </td>

                                <td>
                                    <p>@item.ProductDetailDescription</p>
                                </td>

                                <td>
                                    <p>@item.ProductId</p>
                                </td>

                                <td>
                                    <div class="action">

                                        <form asp-area="Admin"
                                              asp-controller="ProductDetail"
                                              asp-action="DeleteProductDetail"
                                              asp-route-id="@item.ProductDetailId"
                                              method="post">

                                            <button class="text-danger" style="border:none;background:none;">
                                                <i class="lni lni-trash-can"></i> Sil
                                            </button>

                                        </form>

                                    </div>
                                </td>

                                <td>
                                    <div class="action">

                                        <a asp-area="Admin"
                                           asp-controller="ProductDetail"
                                           asp-action="UpdateProductDetail"
                                           asp-route-id="@item.ProductDetailId"
                                           class="text-primary">

                                            <i class="lni lni-pencil"></i> Güncelle
                                        </a>

                                    </div>
                                </td>

                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5">Ürün Detayı Bulunamadı</td>
                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {

        const deleteForms = document.querySelectorAll("form[action*='DeleteProductDetail']");

        deleteForms.forEach(function (form) {

            form.addEventListener("submit", function (e) {

                const confirmDelete = confirm("Bu ürün detayını silmek istediğinize emin misiniz?");

                if (!confirmDelete) {
                    e.preventDefault();
                }

            });

        });

    });
</script>