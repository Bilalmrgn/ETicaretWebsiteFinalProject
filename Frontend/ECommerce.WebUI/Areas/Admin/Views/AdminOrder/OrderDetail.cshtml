@model List<Frontend.DtosLayer.OrderDetailDto.ResultOrderDetailDto>

@{
    ViewData["Title"] = "Sipariş Detayları";
    Layout = "~/Areas/Admin/Views/AdminLayout/_AdminLayout.cshtml";
}

<style>
    @@media (min-width: 992px) {
        .col-lg-6 {
            flex: 0 0 auto !important;
            width: 100% !important;
        }
    }

    .action {
        display: flex;
        gap: 5px;
        min-width: 80px;
    }

    .table-responsive {
        overflow-x: auto;
    }
</style>

<h1>Sipariş Detayları (ID: @ViewBag.OrderId)</h1>

<div class="col-lg-6">
    <div class="card-style mb-30">
        <div class="d-flex justify-content-between align-items-center mb-10">
            <h6 class="mb-10">Ürünler</h6>

            <a asp-area="Admin"
               asp-controller="AdminOrder"
               asp-action="Index"
               class="btn btn-primary">
                Sipariş Listesine Dön
            </a>
        </div>

        <p class="text-sm mb-20">
            Seçilen siparişe ait ürün detayları listelenir.
        </p>

        <div class="table-wrapper table-responsive">
            <table class="table striped-table">
                <thead>
                    <tr>
                        <th><h6>Ürün ID</h6></th>
                        <th><h6>Ürün Adı</h6></th>
                        <th><h6>Birim Fiyat</h6></th>
                        <th><h6>Adet</h6></th>
                        <th><h6>Toplam</h6></th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td><p>@item.ProductId</p></td>
                                <td><p>@item.ProductName</p></td>
                                <td><p>@item.ProductPrice.ToString("N2") ₺</p></td>
                                <td><p>@item.ProductAmount</p></td>
                                <td><p>@((item.ProductPrice * item.ProductAmount).ToString("N2")) ₺</p></td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5">Bu siparişe ait ürün detayı bulunamadı.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
