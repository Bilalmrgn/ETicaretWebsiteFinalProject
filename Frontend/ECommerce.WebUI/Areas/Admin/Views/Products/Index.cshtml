@model List<Frontend.DtosLayer.ProductsDto.ProductListDto>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Areas/Admin/Views/AdminLayout/_AdminLayout.cshtml";
}

<style>
    @@media (min-width: 992px) {
        .col-lg-6 {
            flex: 0 0 auto !important;
            width: 100% !important;
        }
    }


    /* Tablonun kapsayıcısını tam genişlik yap */
    .col-lg-12-custom {
        width: 100% !important;
        padding: 0 15px;
    }
    /* Butonların yan yana düzgün durması için */
    .action {
        display: flex;
        gap: 5px;
        min-width: 80px;
    }
    /* Tablo çok genişse sağa kaydırılabilir yap */
    .table-responsive {
        overflow-x: auto;
    }
</style>

<h1>Index</h1>

<div class="col-lg-6">
    <div class="card-style mb-30">

        <div class="d-flex justify-content-between align-items-center mb-10">

            <h6 class="mb-10">Ürünler</h6>

            <a asp-area="Admin"
               asp-controller="Products"
               asp-action="CreateProduct"
               class="btn btn-primary">
                + Ürün Ekle
            </a>

        </div>

        <p class="text-sm mb-20">
            For Striped Table—light padding and only horizontal dividers.
        </p>

        <div class="table-wrapper table-responsive">

            <table class="table striped-table">

                <thead>
                    <tr>
                        <th>
                            <h6>Görsel</h6>
                        </th>
                        <th>
                            <h6>Ürün Adı</h6>
                        </th>

                        <th>
                            <h6>Fiyat</h6>
                        </th>

                        <th>
                            <h6>Açıklama</h6>
                        </th>
                        <th>
                            <h6>Kategori</h6>
                        </th>
                        <th>
                            <h6>Sil</h6>
                        </th>

                        <th>
                            <h6>Güncelle</h6>
                        </th>
                        <th>
                            <h6>Ürün Görselleri</h6>
                        </th>
                        <th>
                            <h6>Ürün Detay ve Açıklama</h6>
                        </th>
                    </tr>
                </thead>

                <tbody>

                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>

                                <td>
                                    <img src="@item.ProductImageUrl" style="width:60px;height:60px;object-fit:cover;" />
                                </td>

                                <td>
                                    <p>@item.ProductName</p>
                                </td>

                                <td>
                                    <p>@item.ProductPrice ₺</p>
                                </td>

                                <td>
                                    <p>@item.ProductDescription</p>
                                </td>
                                <td>
                                    <p>@(item.Category != null ? item.Category.CategoryName : "Kategori Yok")</p>
                                </td>


                                @* sil butonu *@
                                <td>
                                    <div class="action">

                                        <form asp-area="Admin"
                                              asp-controller="Products"
                                              asp-action="DeleteProduct"
                                              asp-route-id="@item.ProductId"
                                              method="post">

                                            <button type="submit" class="btn btn-danger" style="color: white !important; background-color: #d9534f !important; padding: 5px 15px;">
                                                Sil
                                            </button>

                                        </form>

                                    </div>
                                </td>
                                @* Güncelle butonu *@
                                <td>
                                    <div class="action">

                                        <a asp-area="Admin"
                                           asp-controller="Products"
                                           asp-action="UpdateProduct"
                                           asp-route-id="@item.ProductId"
                                           class="btn btn-success">

                                            <i class="lni lni-pencil"></i> Güncelle

                                        </a>

                                    </div>
                                </td>
                                @* ürün görselleri butonu *@
                                <td>
                                    <div class="action">
                                        <a asp-area="Admin"
                                           asp-controller="ProductImage"
                                           asp-action="CreateProductImage"
                                           asp-route-id="@item.ProductId"
                                           class="btn btn-warning">

                                            Ürün Görselleri
                                        
                                        </a>
                                    </div>
                                </td>
                                
                                <td>
                                    <div class="action">
                                        <a asp-area="Admin"
                                           asp-controller="ProductDetail"
                                           asp-action="UpdateProductDetail"
                                           asp-route-id="@item.ProductId"
                                           class="btn btn-success">

                                            Ürün Detay ve Açıklama
                                        
                                        </a>
                                    </div>
                                </td>

                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7">No Product Found</td>
                        </tr>
                    }

                </tbody>

            </table>

        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {

        const deleteForms = document.querySelectorAll("form[action*='DeleteProduct']");

        deleteForms.forEach(function (form) {

            form.addEventListener("submit", function (e) {

                const confirmDelete = confirm("Bu ürünü silmek istediğinize emin misiniz?");

                if (!confirmDelete) {
                    e.preventDefault();
                }

            });

        });

    });
</script>