@model Frontend.DtosLayer.ProductsDto.CreateProductDto

@{
    ViewData["Title"] = "CreateProduct";
    Layout = "~/Areas/Admin/Views/AdminLayout/_AdminLayout.cshtml";
}

<h3>Ürün Ekle</h3>

<form method="post">

    <div class="mb-3">
        <label>Ürün Adı</label>
        <input type="text" asp-for="ProductName" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Ürün Fiyatı</label>
        <input type="text" asp-for="ProductPrice" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Ürün Görsel Url</label>
        <input type="text" asp-for="ProductImageUrl" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Ürün Açıklaması</label>
        <textarea asp-for="ProductDescription" class="form-control"></textarea>
    </div>

    <div class="mb-3">
        <label>Kategori</label>

        <select asp-for="CategoryId" class="form-control">

            @foreach (var item in ViewBag.categories)
            {
                <option value="@item.CategoryId">
                    @item.CategoryName
                </option>
            }

        </select>

    </div>

    <button type="submit" class="btn btn-success">
        Kaydet
    </button>

    <a asp-action="Index"
       asp-controller="Products"
       asp-area="Admin"
       class="btn btn-secondary">
        Geri
    </a>

</form>